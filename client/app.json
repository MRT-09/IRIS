{
  "expo": {
    "name": "IRIS",
    "slug": "iris",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iris",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "IRIS uses the camera to capture face photos for contact enrollment.",
        "NSPhotoLibraryUsageDescription": "IRIS reads photos from your library to enroll face images for contacts.",
        "NSMicrophoneUsageDescription": "IRIS checks audio input devices to detect if Bluetooth earbuds are connected.",
        "NSBluetoothAlwaysUsageDescription": "IRIS detects Bluetooth audio devices to decide whether to use TTS or notifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a7ea4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0a7ea4"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "IRIS reads photos to enroll face images for contacts.",
          "cameraPermission": "IRIS uses the camera to capture face photos."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "IRIS checks audio devices to detect if Bluetooth earbuds are connected."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
